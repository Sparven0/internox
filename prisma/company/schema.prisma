// Per-company database — one identical schema is provisioned per onboarded company.
// A PrismaClient is created per company at runtime using the PrismaPg adapter,
// pointed at the company's dedicated pool (see src/DATABASE/connectionManager.ts).
// `prisma generate` and `prisma migrate` (point it at any company DB or a dev clone).

generator client {
  provider = "prisma-client-js"
  output   = "../../src/__generated__/company"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  domain          String               @unique
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  users           User[]
  integrations    CompanyIntegration[]
  customers       Customer[]
  fortnoxSyncLogs FortnoxSyncLog[]

  @@map("companies")
}

model User {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String             @unique
  password         String
  companyId        String             @map("company_id") @db.Uuid
  role             String             @default("employee")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  imapCredentials   ImapCredential[]
  employeeCustomers EmployeeCustomer[]
  timeEntries       TimeEntry[]
  emailActivities   EmailActivity[]
  emails            Email[]

  @@map("users")
}

model CompanyIntegration {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  service      String
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, service])
  @@map("company_integrations")
}

model ImapCredential {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String?  @map("user_id") @db.Uuid
  imapHost          String   @map("imap_host")
  imapPort          Int      @default(993) @map("imap_port")
  emailAddress      String   @map("email_address")
  encryptedPassword String   @map("encrypted_password")
  useTls            Boolean  @default(true) @map("use_tls")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails            Email[]

  @@map("imap_credentials")
}

model Customer {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fortnoxCustomerNumber String?            @map("fortnox_customer_number")
  name                  String
  domain                String?
  companyId             String             @map("company_id") @db.Uuid
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeCustomers     EmployeeCustomer[]
  timeEntries           TimeEntry[]
  emailActivities       EmailActivity[]
  emails                Email[]
  fortnoxCustomer       FortnoxCustomer?
  fortnoxInvoices       FortnoxInvoice[]

  @@map("customers")
}

model EmployeeCustomer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(6)
  assignedBy String?  @map("assigned_by") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([userId, customerId])
  @@map("employee_customer")
}

model TimeEntry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  customerId      String?   @map("customer_id") @db.Uuid
  date            DateTime  @db.Date
  hours           Decimal   @db.Decimal(5, 2)
  description     String?
  source          String    @default("bjornlunden")
  rawCustomerName String?   @map("raw_customer_name")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("time_entries")
}

model EmailActivity {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  customerId      String?   @map("customer_id") @db.Uuid
  sentAt          DateTime  @map("sent_at") @db.Timestamp(6)
  recipientEmail  String    @map("recipient_email")
  recipientDomain String    @map("recipient_domain")
  subject         String?
  messageId       String?   @unique @map("message_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("email_activity")
}

// ─────────────────────────────────────────────────────────────────────────────
// emails – normalized, provider-agnostic email storage
// ─────────────────────────────────────────────────────────────────────────────
model Email {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// RFC 2822 Message-ID header – globally unique, used to prevent duplicates
  messageId        String          @unique @map("message_id")
  /// Source provider: 'imap' | 'gmail' | 'outlook' | 'exchange' | …
  source           String          @default("imap")
  imapCredentialId String?         @map("imap_credential_id") @db.Uuid
  /// Auto-populated by DB trigger matching from_address → users.email
  userId           String?         @map("user_id") @db.Uuid
  customerId       String?         @map("customer_id") @db.Uuid
  /// 'sent' | 'received'
  direction        String          @default("sent")
  subject          String?
  fromAddress      String          @map("from_address")
  fromName         String?         @map("from_name")
  /// JSONB arrays of {address: string, name?: string}
  toAddresses      Json            @default("[]") @map("to_addresses")
  ccAddresses      Json            @default("[]") @map("cc_addresses")
  bccAddresses     Json            @default("[]") @map("bcc_addresses")
  replyTo          String?         @map("reply_to")
  sentAt           DateTime?       @map("sent_at") @db.Timestamptz(6)
  bodyText         String?         @map("body_text")
  bodyHtml         String?         @map("body_html")
  inReplyTo        String?         @map("in_reply_to")
  threadId         String?         @map("thread_id")
  /// Mailbox name where it was found, e.g. 'INBOX', '[Gmail]/Sent Mail'
  mailbox          String?
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamp(6)

  imapCredential   ImapCredential? @relation(fields: [imapCredentialId], references: [id], onDelete: SetNull)
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer         Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("emails")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fortnox data cache tables
// ─────────────────────────────────────────────────────────────────────────────
model FortnoxCustomer {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerNumber     String           @unique @map("customer_number")
  /// Optional link to our normalised Customer row (one-to-one)
  customerId         String?          @unique @map("customer_id") @db.Uuid
  name               String
  organisationNumber String?          @map("organisation_number")
  email              String?
  phone              String?
  address            String?
  zipCode            String?          @map("zip_code")
  city               String?
  country            String?
  currency           String?
  active             Boolean          @default(true)
  /// Full Fortnox API response, preserved for forward-compatibility
  rawData            Json?            @map("raw_data")
  syncedAt           DateTime         @default(now()) @map("synced_at") @db.Timestamp(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  customer           Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoices           FortnoxInvoice[]

  @@map("fortnox_customers")
}

model FortnoxInvoice {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber   String              @unique @map("invoice_number")
  customerNumber  String              @map("customer_number")
  /// Optional link to our normalised Customer row
  customerId      String?             @map("customer_id") @db.Uuid
  invoiceDate     DateTime            @map("invoice_date") @db.Date
  dueDate         DateTime?           @map("due_date") @db.Date
  totalExclVat    Decimal?            @map("total_excl_vat") @db.Decimal(12, 2)
  totalInclVat    Decimal?            @map("total_incl_vat") @db.Decimal(12, 2)
  vat             Decimal?            @db.Decimal(12, 2)
  currency        String              @default("SEK")
  /// e.g. 'unpaid' | 'paid' | 'overdue' | 'cancelled'
  status          String?
  ourReference    String?             @map("our_reference")
  yourReference   String?             @map("your_reference")
  /// Full Fortnox API response, preserved for forward-compatibility
  rawData         Json?               @map("raw_data")
  syncedAt        DateTime            @default(now()) @map("synced_at") @db.Timestamp(6)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamp(6)

  fortnoxCustomer FortnoxCustomer     @relation(fields: [customerNumber], references: [customerNumber])
  customer        Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  rows            FortnoxInvoiceRow[]

  @@map("fortnox_invoices")
}

model FortnoxInvoiceRow {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber String         @map("invoice_number")
  rowNumber     Int?           @map("row_number")
  articleNumber String?        @map("article_number")
  description   String?
  quantity      Decimal?       @db.Decimal(10, 2)
  price         Decimal?       @db.Decimal(12, 2)
  vatPercent    Decimal?       @map("vat_percent") @db.Decimal(5, 2)
  total         Decimal?       @db.Decimal(12, 2)

  invoice       FortnoxInvoice @relation(fields: [invoiceNumber], references: [invoiceNumber], onDelete: Cascade)

  @@map("fortnox_invoice_rows")
}

model FortnoxSyncLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  resource     String
  lastSyncedAt DateTime @map("last_synced_at") @db.Timestamp(6)
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, resource])
  @@map("fortnox_sync_log")
}
